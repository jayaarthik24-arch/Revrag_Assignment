name: Build and Deploy

on:
  push:
    branches: [ main ]

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
steps:

      - name: Checkout code
        uses: actions/checkout@v4

      - name: Build Docker image
        run: docker build -t myuser/myapp:latest .

      - name: Push to Docker Hub
        run: |
          echo "${{ secrets.DOCKER_HUB_PASSWORD }}" | docker login -u myuser --password-stdin
          docker push myuser/myapp:latest

      - name: Deploy to production
        run: |
          ssh -o StrictHostKeyChecking=no deploy@${{ secrets.SERVER_IP }} \
            "docker pull myuser/myapp:latest && docker run -d -p 80:3000 myuser/myapp:latest"
